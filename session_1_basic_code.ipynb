   "source": [
    "# to start with data\n",
    "libname demo '/foldername'\n",
    "data demo.trail;\n",
    "input eid name$ salary;\n",
    "datalines;\n",
    "1 hema 2200\n",
    "2 meera 2100\n",
    "3 kumar 2000\n",
    ";\n",
    "run;\n",
    "proc print data=trail; \n",
    "title Result;\n",
    "run;\n",
    "\n",
    "\n",
    "# to copy old data / clone\n",
    "data trail5;\n",
    "set demo.trail;\n",
    "mul=salary*2;\n",
    "run;\n",
    "\n",
    "\n",
    "# to create chart\n",
    "proc Gchart data=trail;\n",
    "title my first chart;\n",
    "vbar mul;\n",
    "mul;"
   ]
